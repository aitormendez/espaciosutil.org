#!/bin/sh

set -eu

msg_file="$1"
filtered="$(sed '/^#/d;/^[[:space:]]*$/d' "$msg_file")"

if [ -z "$filtered" ]; then
  exit 0
fi

line_count="$(printf '%s\n' "$filtered" | wc -l | tr -d ' ')"
subject="$(printf '%s\n' "$filtered" | head -n 1)"

if [ "$line_count" -ne 1 ]; then
  echo "Error: el mensaje de commit debe ocupar una sola linea." >&2
  echo "Formato esperado: tipo(scope): descripcion en espanol" >&2
  exit 1
fi

case "$subject" in
  Merge\ *|Revert\ *)
    exit 0
    ;;
esac

pattern='^(build|chore|ci|docs|feat|fix|refactor|style|test)(\([[:alnum:]._/-]+\))?: .+'

if ! printf '%s\n' "$subject" | LC_ALL=C grep -Eq "$pattern"; then
  echo "Error: el mensaje no sigue Conventional Commits." >&2
  echo "Usa: tipo(scope): descripcion en espanol" >&2
  echo "Ejemplo: feat(coupons): implementa cupones de PMPro para la beta del CDE" >&2
  exit 1
fi

description="$(printf '%s\n' "$subject" | sed -E 's/^[^:]+: //')"

low_signal_pattern='^(cambios|ajustes|mejoras|misc|wip|tmp|update|fix|chore|refactor)$'

if printf '%s\n' "$description" | LC_ALL=C grep -Eiq "$low_signal_pattern"; then
  echo "Error: la descripcion del commit es demasiado generica." >&2
  echo "Describe el conjunto real de cambios incluidos." >&2
  echo "Ejemplo: feat(coupons): implementa cupones de PMPro para la beta del CDE" >&2
  exit 1
fi

generic_verb_pattern='^(actualiza(r)?|cambia(r)?|ajusta(r)?|mejora(r)?|corrige(r)?|refactoriza(r)?)\b'
word_count="$(printf '%s\n' "$description" | awk '{print NF}')"

if [ "$word_count" -le 4 ] && printf '%s\n' "$description" | LC_ALL=C grep -Eiq "$generic_verb_pattern"; then
  echo "Error: la descripcion del commit es demasiado generica." >&2
  echo "Describe el conjunto real de cambios incluidos." >&2
  echo "Ejemplo: feat(coupons): implementa cupones de PMPro para la beta del CDE" >&2
  exit 1
fi
